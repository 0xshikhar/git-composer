{
  "name": "vscode-commit-composer",
  "displayName": "Git Commit Composer",
  "description": "Intelligently group staged changes into logical commits using AI",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "commitComposer.autoCompose",
        "title": "Commit Composer: Auto Compose"
      }
    ],
    "configuration": {
      "title": "Commit Composer",
      "properties": {
        "commitComposer.aiProvider": {
          "type": "string",
          "enum": [
            "openai",
            "anthropic",
            "google",
            "ollama"
          ],
          "default": "openai",
          "description": "AI Provider to use for generating commits"
        },
        "commitComposer.apiKey": {
          "type": "string",
          "default": "",
          "description": "API Key for the selected AI provider"
        },
        "commitComposer.model": {
          "type": "string",
          "default": "",
          "description": "Model to use (leave empty for provider default)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "20.x",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/test-electron": "^2.3.8",
    "css-loader": "^7.1.2",
    "eslint": "^8.56.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "diff-match-patch": "^1.0.5",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "simple-git": "^3.22.0",
    "uuid": "^9.0.1"
  }
}
